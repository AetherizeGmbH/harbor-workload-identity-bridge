{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitScope(deps)",
    ":dependencyDashboard",
    ":separateMajorReleases",
    ":disableRateLimiting"
  ],
  "timezone": "Europe/Berlin",
  "platformAutomerge": true,
  "platformCommit": "enabled",
  "automergeStrategy": "squash",
  "labels": ["dependencies"],
  "prConcurrentLimit": 20,
  "prHourlyLimit": 0,
  "rebaseWhen": "behind-base-branch",
  "ignorePaths": ["**/node_modules/**", "**/vendor/**"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "branch"
  },
  "packageRules": [
    {
      "description": "Automerge non-major + patch updates if CI passes",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Major updates: open PR, no automerge — human review",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["major-bump"]
    },
    {
      "description": "Group Go module bumps so we don’t spam",
      "matchManagers": ["gomod"],
      "groupName": "Go modules",
      "groupSlug": "gomod"
    },
    {
      "description": "Group GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "groupSlug": "github-actions",
      "automerge": true
    },
    {
      "description": "Group Helm chart deps + values defaults",
      "matchManagers": ["helmv3", "helm-values"],
      "groupName": "Helm",
      "groupSlug": "helm"
    },
    {
      "description": "Group OpenTofu / Terraform deps under one PR",
      "matchManagers": ["terraform", "terraform-version"],
      "groupName": "OpenTofu",
      "groupSlug": "tofu"
    },
    {
      "description": "Pin Docker base images to digest — ADR-0015 supply-chain hygiene",
      "matchManagers": ["dockerfile", "github-actions"],
      "pinDigests": true
    },
    {
      "description": "golangci/golangci-lint is the binary version (with: version: vX.Y.Z) read by golangci-lint-action, not a Git ref. It cannot be digest-pinned; the action only accepts a release tag string.",
      "matchPackageNames": ["golangci/golangci-lint"],
      "pinDigests": false
    },
    {
      "description": "kubernetes 1.x dependencies in go.mod — keep on minor channel",
      "matchPackageNames": ["/^k8s\\.io//", "/^sigs\\.k8s\\.io//"],
      "groupName": "Kubernetes Go modules",
      "groupSlug": "k8s-gomod"
    }
  ],
  "gomod": {
    "postUpdateOptions": ["gomodTidy", "gomodUpdateImportPaths"]
  },
  "customManagers": [
    {
      "description": "Resolve versions stored in OpenTofu/Terraform variable defaults that the native terraform manager can't follow. Annotate the variable with a `# renovate:` comment on the line above its `default`.",
      "customType": "regex",
      "managerFilePatterns": ["/\\.tf$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+?)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+registryUrl=(?<registryUrl>\\S+))?\\s*\\n\\s*default\\s*=\\s*\"(?:[^\"\\n]*:)?(?<currentValue>[^\":\\n]+)\""
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "addLabels": ["security"],
    "automerge": true
  }
}
